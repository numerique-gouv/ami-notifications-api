# Copy this file to `.env.local`, then modify it with your local needs.
# Variables in this file will be auto-loaded when using `make dev`.
DEBUG="false"
DATABASE_URL="postgres://postgres:some_password@localhost:5432/postgres"
DATA_WARE_HOUSE_URL="postgres://postgres:some_password@localhost:5432/postgres"

AUTH_COOKIE_JWT_SECRET=""

PUBLIC_API_URL="https://localhost:8000"
PUBLIC_APP_URL="https://localhost:5173"

PUBLIC_MATOMO_ENABLED="true"
PUBLIC_MATOMO_URL="https://stats.data.gouv.fr/"
PUBLIC_MATOMO_CDN_URL="https://stats.data.gouv.fr/"
PUBLIC_MATOMO_SITE_ID="315"

#### FranceConnect login proxy. This should be empty in production.
PUBLIC_FC_PROXY=""

#### FranceConnect AMI variables
FC_AMI_CLIENT_ID="33fe498cc172fe691778912a2967baa650b24f1ae0ebbe47ae552f37b2d25ead"
FC_AMI_CLIENT_SECRET="fake secret for AMI"
PUBLIC_FC_BASE_URL="https://fcp-low.sbx.dev-franceconnect.fr"
PUBLIC_FC_LOGOUT_ENDPOINT="/api/v2/session/end"
FC_SCOPE="openid identite_pivot preferred_username email cnaf_enfants cnaf_adresse"

#### Pro Connect AMI admin variables
PRO_CONNECT_AGENT_ADMIN_CLIENT_ID="1c68542c1a7a427dd526c78e02293a3d1c101709c08294e691ce28926dd48ee1"
PRO_CONNECT_AGENT_ADMIN_CLIENT_SECRET="fake secret for AMI admin"
PRO_CONNECT_BASE_URL="https://fca.integ01.dev-agentconnect.fr"

#### API Particulier variables
API_PARTICULIER_BASE_URL="https://staging.particulier.api.gouv.fr"
API_PARTICULIER_RECIPIENT_ID="13002526500013"

#### API data.education.gouv variables
API_DATA_EDUCATION_BASE_URL="https://data.education.gouv.fr"

#### API Géoplateforme - Géocodage variables
PUBLIC_API_GEO_PLATEFORME_BASE_URL="https://data.geopf.fr/geocodage"
PUBLIC_API_GEO_PLATEFORME_SEARCH_ENDPOINT="/search"

#### Partners
PARTNERS_PSL_SECRET=""
#### PSL OTV variable
PARTNERS_PSL_OTV_REQUEST_URL="https://psl-int-cgi-pslexec.pic-snau.service-public.fr/mademarche/demarcheGenerique/?codeDemarche=OperationTranquilliteVacances&caller=AMI"
PARTNERS_PSL_OTV_JWT_CERT_PFX_B64=""
PARTNERS_PSL_OTV_JWT_CERT_PUBLIC_KEY=""
PARTNERS_PSL_OTV_JWE_PUBLIC_KEY=""
PARTNERS_DINUM_DN_SECRET=""
PARTNERS_DINUM_AMI_SECRET=""

#### User identity: COG (Code Insee) to name queries
PUBLIC_API_GEO_CITY_QUERY_BASE_URL="https://geo.api.gouv.fr"
PUBLIC_API_GEO_CITY_QUERY_ENDPOINT="/communes/{birthplace}?fields=nom&format=json"
PUBLIC_API_GEO_COUNTRY_QUERY_BASE_URL="https://tabular-api.data.gouv.fr"
PUBLIC_API_GEO_COUNTRY_QUERY_ENDPOINT="/api/resources/3580bf65-1d11-4574-a2ca-903d64ad41bd/data/?page=1&page_size=20&COG__exact="

#### TCHAP canal variable
PUBLIC_CONTACT_URL="https://www.tchap.gouv.fr/#/room/!pwyfzLTDXyMeinVsgL:agent.dinum.tchap.gouv.fr"
